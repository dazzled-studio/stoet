---
import Base from '../layouts/Base.astro';
import { m } from '../paraglide/messages.js';
---
<Base transparentNav={true}>
  <!-- HERO -->
  <section class="relative min-h-[88vh] flex items-end overflow-hidden">
    <img
      src="/images/hero-food.jpg"
      alt={m.home_hero_eyebrow()}
      class="absolute inset-0 w-full h-full object-cover"
      fetchpriority="high"
      width="1600"
      height="1067"
    />
    <!-- Top-to-bottom darkening for nav legibility -->
    <div class="absolute inset-0 bg-gradient-to-b from-ink/55 via-ink/25 to-ink/85"></div>
    <!-- Left-side stronger scrim so headline holds up -->
    <div class="absolute inset-0 bg-gradient-to-r from-ink/75 via-ink/40 to-transparent lg:to-ink/0"></div>

    <div class="relative w-full max-w-[1300px] mx-auto px-5 lg:px-10 pb-20 lg:pb-28 pt-32 text-paper">
      <div class="max-w-2xl">
        <div class="flex items-center gap-3 mb-6">
          <span class="accent-rule" style="background: var(--color-accent-soft)"></span>
          <span class="eyebrow !text-paper/90">{m.home_hero_eyebrow()}</span>
        </div>
        <h1 class="headline text-[clamp(2.5rem,6vw,5rem)]" style="text-shadow: 0 2px 30px rgba(20,16,14,0.45);">
          {m.home_hero_headline()}
        </h1>
        <p class="mt-6 max-w-xl text-paper text-lg leading-relaxed" style="text-shadow: 0 1px 14px rgba(20,16,14,0.55);">
          {m.home_hero_sub()}
        </p>
        <div class="mt-10 flex flex-wrap gap-3">
          <a href="/menu" class="btn btn-primary">{m.home_hero_cta_primary()}</a>
          <a href="/contact" class="btn btn-ghost">{m.home_hero_cta_secondary()}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- INTRO / ABOUT -->
  <section class="bg-paper">
    <div class="max-w-[1300px] mx-auto px-5 lg:px-10 py-24 lg:py-32 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-center">
      <div class="lg:col-span-6 reveal">
        <div class="flex items-center gap-3 mb-5">
          <span class="accent-rule"></span>
          <span class="eyebrow">{m.home_intro_eyebrow()}</span>
        </div>
        <h2 class="headline font-display text-[clamp(2rem,4vw,3.25rem)] mb-8">
          {m.home_intro_headline()}
        </h2>
        <p class="text-ink-soft mb-5">{m.home_intro_body_1()}</p>
        <p class="text-ink-soft">{m.home_intro_body_2()}</p>
        <a href="/over-ons" class="link-line mt-10 inline-block font-medium text-sm tracking-wide">
          {m.home_feature_cta()}
        </a>
      </div>

      <div class="lg:col-span-6 reveal" style="transition-delay: 100ms">
        <div class="relative">
          <img
            src="/images/food-instagram-2.jpg"
            alt={m.home_intro_headline()}
            class="w-full aspect-[4/5] object-cover rounded-md"
            loading="lazy"
            width="1280"
            height="1600"
          />
          <div class="absolute -bottom-6 -left-6 bg-paper-warm px-6 py-5 hidden md:block rounded-md border border-line">
            <div class="font-display text-3xl text-ink">2016</div>
            <div class="text-xs uppercase tracking-[0.14em] text-muted mt-1">Sinds september</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURE: BREAD STORY -->
  <section class="bg-paper-warm">
    <div class="max-w-[1300px] mx-auto px-5 lg:px-10 py-24 lg:py-32 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-center">
      <div class="lg:col-span-6 order-2 lg:order-1 reveal">
        <img
          src="/images/unsplash/bread-1.jpg"
          alt={m.home_feature_headline()}
          class="w-full aspect-[4/5] object-cover rounded-md"
          loading="lazy"
          width="1600"
          height="2133"
        />
      </div>
      <div class="lg:col-span-6 order-1 lg:order-2 reveal" style="transition-delay: 80ms">
        <div class="flex items-center gap-3 mb-5">
          <span class="accent-rule"></span>
          <span class="eyebrow">{m.home_feature_eyebrow()}</span>
        </div>
        <h2 class="headline font-display text-[clamp(2rem,4vw,3.25rem)] mb-8">
          {m.home_feature_headline()}
        </h2>
        <p class="text-ink-soft">{m.home_feature_body()}</p>
        <a href="/menu" class="btn btn-dark mt-10">{m.common_view_menu()}</a>
      </div>
    </div>
  </section>

  <!-- GALLERY -->
  <section class="bg-paper">
    <div class="max-w-[1300px] mx-auto px-5 lg:px-10 py-24 lg:py-32">
      <div class="max-w-2xl mb-14 reveal">
        <div class="flex items-center gap-3 mb-5">
          <span class="accent-rule"></span>
          <span class="eyebrow">{m.home_gallery_eyebrow()}</span>
        </div>
        <h2 class="headline font-display text-[clamp(2rem,4vw,3.25rem)]">
          {m.home_gallery_headline()}
        </h2>
        <p class="mt-5 text-ink-soft">{m.home_gallery_caption()}</p>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-3 gap-3 lg:gap-5">
        {[
          { src: '/images/food-instagram-1.jpg', alt: 'Bovenaanzicht van het lunchaanbod bij Stoet' },
          { src: '/images/unsplash/sandwich-1.jpg', alt: 'Versgebakken sandwich op een bord' },
          { src: '/images/unsplash/toast-greens.jpg', alt: 'Open boterham met groenten' },
          { src: '/images/unsplash/brunch-spread.jpg', alt: 'Brunchtafel met meerdere borden' },
          { src: '/images/unsplash/dessert.jpg', alt: 'Zoete lekkernij op een wit bord' },
          { src: '/images/unsplash/bread-2.jpg', alt: 'Ambachtelijk gebakken brood' },
        ].map((img, i) => (
          <div
            class="reveal overflow-hidden rounded-md aspect-[4/5]"
            style={`transition-delay: ${i * 60}ms`}
          >
            <img src={img.src} alt={img.alt} loading="lazy" class="w-full h-full object-cover hover:scale-[1.03] transition-transform duration-700" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- VISIT -->
  <section class="bg-ink text-paper">
    <div class="max-w-[1300px] mx-auto px-5 lg:px-10 py-24 lg:py-32 grid grid-cols-1 lg:grid-cols-12 gap-12">
      <div class="lg:col-span-7 reveal">
        <div class="flex items-center gap-3 mb-5">
          <span class="accent-rule" style="background: var(--color-accent-soft)"></span>
          <span class="eyebrow !text-paper/60">{m.home_visit_eyebrow()}</span>
        </div>
        <h2 class="headline font-display text-[clamp(2rem,5vw,4rem)] mb-8">
          {m.home_visit_headline()}
        </h2>
        <p class="text-paper/80 max-w-xl">{m.home_visit_body()}</p>
        <div class="mt-10 flex flex-wrap gap-3">
          <a href="https://maps.google.com/?q=Pijpenstraat+15+Enschede" target="_blank" rel="noopener" class="btn btn-ghost">{m.home_visit_cta()}</a>
          <a href={`tel:${m.contact_phone_tel()}`} class="btn btn-ghost">{m.common_call_us()}</a>
        </div>
      </div>

      <div class="lg:col-span-5 reveal" style="transition-delay: 100ms">
        <div class="bg-paper/5 border border-paper/10 p-8 rounded-md">
          <div class="eyebrow !text-paper/50 mb-2">{m.contact_hours_label()}</div>
          <p class="text-paper">{m.contact_hours_value()}.</p>
          <p class="text-paper/60 text-sm mt-1">{m.contact_hours_sunday()}.</p>

          <div class="section-line bg-paper/10 my-6"></div>

          <div class="eyebrow !text-paper/50 mb-2">{m.contact_address_street()}</div>
          <address class="not-italic text-paper">
            {m.contact_address_street()}<br />
            {m.contact_address_postal_city()}
          </address>

          <div class="section-line bg-paper/10 my-6"></div>

          <a href={`tel:${m.contact_phone_tel()}`} class="block text-paper hover:text-paper transition link-line mb-2">{m.contact_phone_display()}</a>
          <a href={`mailto:${m.contact_email()}`} class="block text-paper hover:text-paper transition link-line">{m.contact_email()}</a>
        </div>
      </div>
    </div>
  </section>
</Base>
