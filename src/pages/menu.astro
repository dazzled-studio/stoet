---
import Base from '../layouts/Base.astro';
import { m } from '../paraglide/messages.js';
import { menu, formatPrice } from '../data/menu.ts';

const messageMap = m as unknown as Record<string, () => string>;
---
<Base title={`${m.nav_menu()}. ${m.site_title()}`} description={m.menu_hero_sub()}>
  <!-- HERO -->
  <section class="relative pt-32 pb-20 lg:pt-40 lg:pb-24 bg-paper">
    <div class="max-w-[1300px] mx-auto px-5 lg:px-10 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-7">
        <div class="flex items-center gap-3 mb-5">
          <span class="accent-rule"></span>
          <span class="eyebrow">{m.menu_hero_eyebrow()}</span>
        </div>
        <h1 class="headline font-display text-[clamp(2.5rem,6vw,5rem)] mb-8">
          {m.menu_hero_headline()}
        </h1>
        <p class="text-ink-soft max-w-xl text-lg leading-relaxed">
          {m.menu_hero_sub()}
        </p>
      </div>
      <div class="lg:col-span-5 hidden lg:block">
        <img src="/images/unsplash/bread-2.jpg" alt={m.menu_hero_headline()} class="w-full aspect-[4/5] object-cover rounded-md" width="1600" height="2400" />
      </div>
    </div>
  </section>

  <!-- INDEX -->
  <section class="bg-paper border-y border-line sticky top-20 z-30 backdrop-blur supports-[backdrop-filter]:bg-paper/85">
    <div class="max-w-[1100px] mx-auto px-5 lg:px-10 py-4">
      <nav class="flex flex-wrap gap-x-5 gap-y-2 text-[13px] uppercase tracking-[0.08em] font-medium" aria-label="Op deze pagina">
        {menu.map((cat) => (
          <a href={`#${cat.id}`} class="link-line text-muted hover:text-ink whitespace-nowrap">
            {messageMap[cat.nameKey]()}
          </a>
        ))}
      </nav>
    </div>
  </section>

  <!-- CATEGORIES -->
  <section class="bg-paper">
    <div class="max-w-[1100px] mx-auto px-5 lg:px-10 py-16 lg:py-24">
      <div class="space-y-20 lg:space-y-28">
        {menu.map((cat) => (
          <div id={cat.id} class="scroll-mt-28">
            <div class="mb-10 reveal">
              <div class="flex items-center gap-3 mb-3">
                <span class="accent-rule"></span>
                <span class="eyebrow">{m.menu_hero_eyebrow()}</span>
              </div>
              <h2 class="headline font-display text-[clamp(2rem,4vw,3rem)]">{messageMap[cat.nameKey]()}</h2>
              {cat.subtitleKey && (
                <p class="text-muted text-sm mt-3 max-w-2xl">{messageMap[cat.subtitleKey]()}</p>
              )}
            </div>

            <ul class="divide-y divide-line">
              {cat.items.map((item) => (
                <li class="py-6 grid grid-cols-12 gap-4 reveal">
                  <div class="col-span-12 sm:col-span-9">
                    <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                      <h3 class="font-display text-xl text-ink">{item.name}</h3>
                      {item.tags && item.tags.map((tag) => (
                        <span class="text-[10px] uppercase tracking-[0.16em] font-semibold px-2 py-0.5 rounded-sm bg-accent-soft text-ink">{tag}</span>
                      ))}
                    </div>
                    {item.description && (
                      <p class="text-ink-soft mt-2 text-[15px] leading-relaxed">{item.description}</p>
                    )}
                    {item.note && (
                      <p class="text-muted mt-2 text-[13px] italic">{item.note}</p>
                    )}
                    {item.addons && item.addons.length > 0 && (
                      <p class="text-muted mt-2 text-[13px]">
                        <span class="eyebrow !text-xs !tracking-[0.12em] mr-2">{m.menu_addon_label()}</span>
                        {item.addons.map((a, i) => (
                          <span>{i > 0 && ', '}{a.name} ({formatPrice(a.price)})</span>
                        ))}
                      </p>
                    )}
                    {item.allergens && item.allergens.length > 0 && (
                      <p class="text-muted mt-2 text-[12px] tracking-wide">
                        <span class="eyebrow !text-xs !tracking-[0.12em] mr-2">{m.menu_allergens_label()}</span>
                        {item.allergens.join(' · ')}
                      </p>
                    )}
                  </div>
                  <div class="col-span-12 sm:col-span-3 sm:text-right">
                    <span class="font-display text-xl text-ink whitespace-nowrap">
                      {item.priceLabel || (item.price !== undefined ? formatPrice(item.price) : '')}
                    </span>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <div class="mt-24 bg-paper-warm border border-line rounded-md p-8 lg:p-10">
        <div class="eyebrow mb-3">{m.menu_legend_title()}</div>
        <h2 class="font-display text-2xl mb-4 text-ink">{m.menu_legend_title()}</h2>
        <p class="text-ink-soft">{m.menu_legend_intro()}</p>
        <ul class="mt-6 space-y-2 text-sm text-muted">
          <li>{m.menu_note_bread()}</li>
          <li>{m.menu_note_sauces()}</li>
          <li>{m.menu_note_pricing()}</li>
        </ul>
      </div>
    </div>
  </section>
</Base>
