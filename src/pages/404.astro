---
import Base from '../layouts/Base.astro';
import { m } from '../paraglide/messages.js';
---
<Base title={`404. ${m.site_title()}`}>
  <section class="min-h-[70vh] flex items-center bg-paper">
    <div class="max-w-[1300px] mx-auto px-5 lg:px-10 py-32 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-7">
        <div class="flex items-center gap-3 mb-5">
          <span class="accent-rule"></span>
          <span class="eyebrow">404</span>
        </div>
        <h1 class="headline font-display text-[clamp(2.5rem,6vw,5rem)] mb-6">
          {m.page_not_found_headline()}
        </h1>
        <p class="text-ink-soft text-lg mb-10 max-w-md">{m.page_not_found_body()}</p>
        <a href="/" class="btn btn-primary">{m.page_not_found_cta()}</a>
      </div>
      <div class="lg:col-span-5 hidden lg:block">
        <img src="/images/unsplash/bread-1.jpg" alt="" class="w-full aspect-[4/5] object-cover rounded-md" loading="lazy" />
      </div>
    </div>
  </section>
</Base>
